{
  "name": "replace-custom-scrollbars",
  "version": "2.0.1",
  "description": "React scrollbars component, based Malte Wessel/react-custom-scrollbars",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup src/index.ts --format cjs,esm --dts --minify --clean --external react,react-dom",
    "demo": "npm --prefix demo run dev",
    "demo:build": "npm --prefix demo run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/felipecarrillo100/replace-custom-scrollbars.git"
  },
  "keywords": [
    "scroll",
    "scroller",
    "scrollbars",
    "react-component",
    "react",
    "custom"
  ],
  "author": "Felipe Carrillo",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/felipecarrillo100/replace-custom-scrollbars/issues"
  },
  "homepage": "https://github.com/felipecarrillo100/replace-custom-scrollbars#readme",
  "peerDependencies": {
    "react": ">=16.8.0",
    "react-dom": ">=16.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.1.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.12.7",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.1.1",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "globals": "^15.1.0",
    "happy-dom": "^20.9.0",
    "jsdom": "^24.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "rebound": "^0.0.13",
    "sass": "^1.99.0",
    "tsup": "^8.0.2",
    "typedoc": "^0.28.19",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.0.0",
    "vite": "^8.0.11",
    "vitest": "^4.1.5"
  }
}